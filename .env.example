# Copy this to .env and fill in your API key
OPENAI_API_KEY=your-api-key-here

# Optional: override model names
# AGENT_MODEL=gpt-5.3-codex
# AGENT_CLASSIFIER_MODEL=gpt-4o-mini
# AGENT_SUBAGENT_MODEL=gpt-5.3-codex

# Optional: override token budgets
# AGENT_TOKEN_BUDGET=5000
# AGENT_INPUT_TOKENS=4000
# AGENT_OUTPUT_TOKENS=1000

# Optional: override tool iterations
# AGENT_MAX_TOOL_ITERATIONS=3

# Optional: workspace path
# AGENT_WORKSPACE_PATH=workspace/json

# Optional: subagent toggles
# AGENT_USE_RETRIEVAL_SUBAGENT=true
# AGENT_USE_TOOL_SUMMARIZER=true
# AGENT_USE_CONVERSATION_COMPRESSOR=true
# AGENT_USE_MULTI_HOP=true
